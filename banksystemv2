from abc import ABC , abstractmethod

class base(ABC):
    def __init__(self,acc_number,acc_holder,acc_type,acc_balance):
        self._accnum = acc_number
        self.acctype = acc_type
        self._acchol = acc_holder
        self._accbal = acc_balance
    @abstractmethod
    def interest(self):
        pass
    def get_info(self):
        return f"the accoun number: {self.accnum} balance: {self._accbal} holdername: {self.acchol} acctype: {self.acctype}"

class base1(base):
    def __init__(self, _acc_number, _acc_holder, acc_type, _acc_balance):
        super().__init__(_acc_number, _acc_holder, acc_type, _acc_balance)
    
    def interest(self):
        if self.acctype == "saving":
            return f"this is the interest for your balance: {int((7/100)*self._accbal)}" 
        elif self.acctype == "current":
